# Database Configuration
DATABASE_URL="your_database_url_here"
DIRECT_URL="your_direct_database_url_here"

# Server Configuration
PORT=5000
NODE_ENV=development

# Vercel sets VERCEL=1 automatically in production.
# Use Supabase connection pooler URL for DATABASE_URL on serverless.
# Example: postgresql://...@aws-0-...pooler.supabase.com:6543/postgres?pgbouncer=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# CORS Configuration (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,https://your-frontend.vercel.app

# Forecast / Cron Configuration
# Production Prophet training runs via GitHub Actions:
#   .github/workflows/sales-forecast-prophet.yml
#
# GitHub repo secrets (Settings → Secrets and variables → Actions):
#   DATABASE_URL  — Supabase DIRECT URL (port 5432), same value as DIRECT_URL below
#
# Optional GitHub repository variables:
#   FORECAST_DAYS=30
#   FORECAST_MODEL_VERSION=prophet-v1

CRON_SECRET=generate-a-long-random-secret
FORECAST_DAYS=30
FORECAST_MODEL_VERSION=prophet-v1

# Local-only Node scheduler (not used in production when GitHub Actions runs Prophet)
FORECAST_SCHEDULER_ENABLED=false
FORECAST_RUN_ON_STARTUP=false
FORECAST_SCHEDULE_HOUR=2
FORECAST_SCHEDULE_MINUTE=0

# Local manual Prophet training:
#   cd backend && npm run forecast:train
FORECAST_PYTHON_PATH=.venv-forecast/bin/python

# Attendance geolocation (workplace verification)
# Set coordinates to your restaurant location; employees must punch within the geofence radius.
WORKPLACE_LATITUDE=
WORKPLACE_LONGITUDE=
WORKPLACE_GEOFENCE_RADIUS_METERS=150
# Set to false to record location without blocking punches outside the geofence
ATTENDANCE_ENFORCE_GEOFENCE=true
# Minutes after shift start before check-in is marked late (flexi hours)
ATTENDANCE_FLEXI_GRACE_MINUTES=30
